# Required for GitHub OAuth sign-in + JWT auth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
JWT_SECRET=replace-with-a-long-random-secret
APP_URL=http://localhost:5173

# GitHub Copilot token (required for cloud/server deployments — Render, Railway, etc.)
# Get your token locally:  gh auth token
# Must be a gho_ or github_pat_ prefixed token with Copilot access.
# In local dev this can be omitted if you are logged in via `gh auth login`.
COPILOT_GITHUB_TOKEN=gho_your_token_here

# Anthropic API Key (kept for reference; the backend now uses GitHub Copilot SDK)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server port (optional, default: 3001)
PORT=3001

# Bind host (optional)
HOST=0.0.0.0

# Local dev auth bypass toggle
AUTH_BYPASS_LOCAL=false

# Timeout tuning for long-running chat/tool operations
# HTTP timeout for /api/chat (default 960000 = 16 min)
CHAT_REQUEST_TIMEOUT_MS=960000
# Copilot SDK sendAndWait timeout (default 900000 = 15 min)
COPILOT_SEND_AND_WAIT_TIMEOUT_MS=900000

# Enable Microsoft 365 Work IQ integration (optional)
# Set to true to enable M365 tools, email/Teams monitoring, and write actions
WORKIQ_ENABLED=false

# Enable Playwright MCP browser automation (optional)
# Uses official package: @playwright/mcp
PLAYWRIGHT_MCP_ENABLED=false
# For backend/server usage, headless is recommended (default true)
PLAYWRIGHT_MCP_HEADLESS=true
# Web lookup strategy when Playwright MCP is enabled:
# - chatgpt => open chatgpt.com and ask it to web-search first (requires login)
# - direct  => use search engines / source sites directly
PLAYWRIGHT_WEB_SEARCH_MODE=chatgpt
# Optional extra CLI args for Playwright MCP.
# Use shell-style args with spaces.
# Example: --browser=chrome --caps=vision,pdf
PLAYWRIGHT_MCP_EXTRA_ARGS=--browser=chrome --caps=vision,pdf
# Optional stronger model for live-news/browser-heavy prompts.
# Leave empty to keep the current session model.
LIVE_NEWS_MODEL=gpt-5.1

# Finance/Stocks tools (enabled by default unless set to false)
FINANCE_ENABLED=true
# Optional API keys (if omitted, free delayed fallback provider is used)
TWELVE_DATA_API_KEY=
FMP_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Substack Newsletter Digest Pipeline
SUBSTACK_DIGEST_ENABLED=true
SUBSTACK_DIGEST_CRON=0 8 * * *
# Gmail query used by Substack digest pipeline (last 24h newsletters)
SUBSTACK_GMAIL_QUERY=newer_than:1d (from:substack.com OR subject:Substack)

# Notion (for publishing digests)
NOTION_API_KEY=
NOTION_PAGE_ID=
NOTION_PAGE_TITLE=
